{
  "name": "mutagenic-survivors",
  "productName": "Mutagenic Survivors",
  "version": "1.0.0",
  "description": "Mutagenic Survivors — an educational microbial survivors roguelite in a single self-contained index.html (Canvas2D). Achievement-gated armory, Apex mutations, a 12-track procedural soundtrack, and desktop (.exe) + Android (.apk) builds.",
  "main": "main.js",
  "author": "PlutonianSurvivors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.mutagenicsurvivors.game",
    "productName": "Mutagenic Survivors",
    "directories": { "output": "dist" },
    "files": [
      "index.html",
      "main.js",
      "build/icon.*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "artifactName": "MutagenicSurvivors-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mutagenic Survivors"
    },
    "portable": {
      "artifactName": "MutagenicSurvivors-Portable-${version}.exe"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.games"
    }
  }
}
